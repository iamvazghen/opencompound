# RPC for the chain you're protecting
RPC_URL=https://base-sepolia.g.alchemy.com/v2/your_key

# PositionFactory — the keeper enumerates every isolated position from it
FACTORY_ADDRESS=0x059e81658EBcfADF4837a53505674e451535d14c

# Pooled vaults to also guard (comma-separated). Base Sepolia WETH + USDC:
POOLED_VAULTS=0x93c9e2de034c79128Cb3110a5362a8f925A0Bb46,0x23B081088c8528C54FD28901c019C2cF3f0a0D91

# Gas-only keeper key. It can ONLY call guard()/rebalance() (permissionless, risk-reducing) — never
# owner functions, never moves funds. Fund it with a little gas and nothing else. Omit to watch-only.
KEEPER_PRIVATE_KEY=0xyour_gas_only_keeper_key

# Watch without sending txs:
DRY_RUN=true

POLL_INTERVAL_MS=60000
