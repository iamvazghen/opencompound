# Reown / WalletConnect project id (domain-allowlist it in the Reown dashboard)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_reown_project_id

# Server-only (NO NEXT_PUBLIC prefix) — used by the /api/rpc proxy so the key stays off the client.
ALCHEMY_API_KEY=your_alchemy_key

# "testnet" (default) or "mainnet" — drives active chains + which AppKit features are enabled.
NEXT_PUBLIC_NETWORK_MODE=testnet

# Deployed vault addresses per chain (testnet v1 markets are already in lib/config.ts)
# NEXT_PUBLIC_VAULT_V1_84532=0xYourV1Vault
# NEXT_PUBLIC_VAULT_V2_84532=0xYourV2Vault
