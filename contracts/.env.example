# Deployer (use a throwaway key for testnet; a hardware/multisig flow for mainnet)
PRIVATE_KEY=0xyour_deployer_private_key
DEPLOYER_ADDRESS=0xyour_deployer_address

# RPCs
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/your_key
# BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/your_key
# ETH_MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/your_key

# --- v1 deploy (script/Deploy.s.sol) ---
AAVE_POOL=0x07eA79F68B2B3df564D0A34F8e19D9B1e339814b
ASSET=0x4200000000000000000000000000000000000006
VAULT_NAME=OpenCompound WETH
VAULT_SYMBOL=ocWETH
# Production: deploy owner = a Safe multisig / timelock (defaults to the deployer)
# VAULT_OWNER=0xYourSafe

# --- v2 deploy (script/DeployV2.s.sol) ---
# COLLATERAL=0xWstEth
# DEBT_ASSET=0xWeth
# SWAP_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481  # SwapRouter02 (Base)
# POOL_FEE=100
# EMODE_CATEGORY=1

# Block explorer (Etherscan v2 / Basescan)
BASESCAN_API_KEY=your_etherscan_v2_key

# Mainnet-fork tests (test/fork/*) — set to run them; unset = they self-skip
# FORK_RPC_URL=https://ethereum-rpc.publicnode.com
